// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RESTAURANT_OWNER
  USER
  DELIVERY_BOY
}

enum OrderStatus {
  CREATED
  PAYMENT_PENDING
  PAYMENT_VERIFIED
  PENDING_RESTAURANT_APPROVAL
  ACCEPTED
  REJECTED_BY_RESTAURANT
  PREPARING
  READY_FOR_PICKUP
  PICKED_UP
  OUT_FOR_DELIVERY
  DELIVERED
  PAYMENT_FAILED
  CANCELLED
  REFUND_INITIATED
  REFUND_COMPLETED
}

model User {
  id         String   @id @default(uuid())
  name       String
  phone      String   @unique
  email      String?  @unique
  role       Role     @default(USER)
  status     String   @default("ACTIVE")
  created_at DateTime @default(now())

  // Relations
  addresses  Address[]
  restaurant Restaurant? @relation("OwnerRestaurant") // For Restaurant Owners
  orders     Order[]
  deliveries Delivery[] // For Delivery Boys
}

model Address {
  id      String @id @default(uuid())
  user_id String
  lat     Float
  lng     Float
  label   String

  user    User   @relation(fields: [user_id], references: [id])
}

model Restaurant {
  id                 String   @id @default(uuid())
  owner_id           String   @unique
  name               String
  desc               String?
  logo               String?
  status             String   @default("ACTIVE")
  rating             Float    @default(0.0)
  base_delivery_time Int      @default(30)

  owner              User     @relation("OwnerRestaurant", fields: [owner_id], references: [id])
  foods              Food[]
  orders             Order[]
}

model Food {
  id            String     @id @default(uuid())
  restaurant_id String
  name          String
  desc          String?
  price         Float
  image         String?
  category_id   String?
  availability  Boolean    @default(true)

  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id])
  inventory     Inventory?
  order_items   OrderItem[]

  // Critical index for vendor queries
  @@index([restaurant_id])
}

model Inventory {
  food_id   String @id
  stock_qty Int    @default(0)
  threshold Int    @default(5)

  food      Food   @relation(fields: [food_id], references: [id])
}

model Order {
  id             String      @id @default(uuid())
  user_id        String
  restaurant_id  String
  status         OrderStatus @default(CREATED)
  subtotal       Float
  delivery_fee   Float
  total          Float
  payment_status String      @default("PENDING")
  created_at     DateTime    @default(now())

  user           User        @relation(fields: [user_id], references: [id])
  restaurant     Restaurant  @relation(fields: [restaurant_id], references: [id])
  order_items    OrderItem[]
  payment        Payment?
  delivery       Delivery?

  // Critical index for vendor queries
  @@index([restaurant_id])
}

model OrderItem {
  order_id   String
  food_id    String
  qty        Int
  unit_price Float

  order      Order @relation(fields: [order_id], references: [id])
  food       Food  @relation(fields: [food_id], references: [id])

  @@id([order_id, food_id])
}

model Payment {
  order_id    String   @id
  gateway     String
  txn_id      String?
  status      String
  verified_at DateTime?
  raw_payload Json?

  order       Order    @relation(fields: [order_id], references: [id])
}

model Delivery {
  order_id         String    @id
  delivery_boy_id  String
  assigned_at      DateTime  @default(now())
  picked_at        DateTime?
  delivered_at     DateTime?

  order            Order     @relation(fields: [order_id], references: [id])
  delivery_boy     User      @relation(fields: [delivery_boy_id], references: [id])
  locations        DeliveryLocation[]
}

model DeliveryLocation {
  id          String   @id @default(uuid())
  delivery_id String
  lat         Float
  lng         Float
  speed       Float?
  heading     Float?
  timestamp   DateTime @default(now())

  delivery    Delivery @relation(fields: [delivery_id], references: [order_id])
}

model AuditLog {
  id        String   @id @default(uuid())
  actor_id  String
  entity    String
  action    String
  before    Json?
  after     Json?
  timestamp DateTime @default(now())
}
