# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────
# JWT Secret (used for custom auth tokens)
# ──────────────────────────────────────────────
JWT_SECRET=your-jwt-secret

# ──────────────────────────────────────────────
# Google OAuth
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id

# ──────────────────────────────────────────────
# TextBee SMS Gateway
# ──────────────────────────────────────────────
TEXTBEE_API_KEY=your-textbee-api-key
TEXTBEE_API_URL=https://api.textbee.io/api/v1/send

# ──────────────────────────────────────────────
# Country code for SMS (Nepal: +977)
# ──────────────────────────────────────────────
COUNTRY_CODE=+977

# ──────────────────────────────────────────────
# Firebase Cloud Messaging (Android push notifications)
# Uses FCM HTTP v1 API with a service account JSON file.
# Download from: Firebase Console → Project Settings → Service Accounts
# Place the file at: backend/fcm-service-account.json
# ──────────────────────────────────────────────
FCM_SERVICE_ACCOUNT_PATH=./fcm-service-account.json

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=5000
